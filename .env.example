# BOP Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# LLM Backends (choose one or more)
# ============================================================================

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (recommended for best quality)
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Google/Gemini
GEMINI_API_KEY=...
GOOGLE_API_KEY=...  # Alternative name
GOOGLE_MODEL=gemini-2.5-pro

# Groq (fastest, for speed)
GROQ_API_KEY=...

# Default LLM backend and model (optional)
LLM_BACKEND=
LLM_MODEL=

# ============================================================================
# MCP Tools
# ============================================================================

# Perplexity (deep research, reasoning, search)
PERPLEXITY_API_KEY=pplx-...

# Firecrawl (web scraping, extraction)
FIRECRAWL_API_KEY=fc-...

# Tavily (search and content extraction)
TAVILY_API_KEY=tvly-...

# Kagi (web search and summarization)
KAGI_API_KEY=...

# ============================================================================
# BOP Configuration
# ============================================================================

# Constraint solver (for optimal tool selection)
BOP_USE_CONSTRAINTS=false

# Quality feedback loop
BOP_QUALITY_FEEDBACK=true

# Server configuration
BOP_HOST=0.0.0.0
BOP_PORT=8000
PORT=8000  # Fly.io uses this

# API key for server authentication (optional, for production)
BOP_API_KEY=

# ============================================================================
# Development
# ============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
